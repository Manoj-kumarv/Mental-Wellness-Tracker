# ─────────────────────────────────────────────────────────────────────────────
# MindEase Backend — Environment Configuration
# Copy to .env for local development.
# In production all values are set via Elastic Beanstalk Environment Properties
# or injected from AWS Secrets Manager.
# NEVER commit a .env file with real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Application
ENVIRONMENT=development
DEBUG=true

# Security — rotated via AWS Secrets Manager in production
JWT_SECRET_KEY=local-dev-secret-replace-in-prod

# AWS credentials (local dev only — use IAM roles in production, never hardcode)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-local-access-key
AWS_SECRET_ACCESS_KEY=your-local-secret-key

# DynamoDB
DYNAMODB_TABLE_PREFIX=mindease
# Uncomment for local DynamoDB:
# DYNAMODB_ENDPOINT=http://localhost:8000

# S3 buckets (must exist)
S3_PRIVATE_BUCKET=mindease-private-dev
S3_PUBLIC_BUCKET=mindease-public-dev

# AWS Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=us-east-1

# AWS Secrets Manager
USE_SECRETS_MANAGER=false
SECRET_NAME_JWT=mindease/jwt-secret-key

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
